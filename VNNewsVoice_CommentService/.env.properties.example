# CommentService runtime env template (.env.properties)
COMMENT_SERVICE_PORT=8083
COMMENT_DB_URL=jdbc:postgresql://<comment-db-host>:5432/<comment-db-name>
COMMENT_DB_USERNAME=<comment-db-username>
COMMENT_DB_PASSWORD=<comment-db-password>

# Auth/JWKS
AUTH_JWKS_URL=http://<auth-host>:8084/api/.well-known/jwks.json
AUTH_JWKS_CONNECT_TIMEOUT_MS=2000
AUTH_JWKS_READ_TIMEOUT_MS=2000
AUTH_JWKS_CACHE_LIFESPAN_SECONDS=900
AUTH_JWKS_CACHE_REFRESH_SECONDS=300
JWT_ISSUER=vnnewsvoice-auth-service
JWT_AUDIENCE=vnnewsvoice-services
JWT_ALLOW_LEGACY_HS256=false
JWT_VERIFY_ISSUER_AUDIENCE=true
JWT_SECRET=

# RabbitMQ
COMMENT_RABBITMQ_HOST=<rabbitmq-host>
COMMENT_RABBITMQ_PORT=5672
COMMENT_RABBITMQ_USERNAME=<rabbitmq-username>
COMMENT_RABBITMQ_PASSWORD=<rabbitmq-password>
COMMENT_RABBITMQ_VHOST=/
