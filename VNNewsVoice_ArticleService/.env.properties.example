# ArticleService runtime env template (.env.properties)
ARTICLE_SERVICE_PORT=8080
ARTICLE_DB_URL=jdbc:postgresql://<article-db-host>:5432/<article-db-name>
ARTICLE_DB_USERNAME=<article-db-username>
ARTICLE_DB_PASSWORD=<article-db-password>

# Auth/JWKS
AUTH_JWKS_URL=http://<auth-host>:8084/api/.well-known/jwks.json
AUTH_JWKS_CONNECT_TIMEOUT_MS=2000
AUTH_JWKS_READ_TIMEOUT_MS=2000
AUTH_JWKS_CACHE_LIFESPAN_SECONDS=900
AUTH_JWKS_CACHE_REFRESH_SECONDS=300
JWT_ISSUER=vnnewsvoice-auth-service
JWT_AUDIENCE=vnnewsvoice-services
JWT_ALLOW_LEGACY_HS256=false
JWT_VERIFY_ISSUER_AUDIENCE=true
JWT_SECRET=

# CORS
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://app.example.com,https://admin.example.com

# RabbitMQ
ARTICLE_RABBITMQ_HOST=<rabbitmq-host>
ARTICLE_RABBITMQ_PORT=5672
ARTICLE_RABBITMQ_USERNAME=<rabbitmq-username>
ARTICLE_RABBITMQ_PASSWORD=<rabbitmq-password>
ARTICLE_RABBITMQ_VHOST=/

# Retention purge
ARTICLE_LIFECYCLE_PURGE_ENABLED=true
ARTICLE_LIFECYCLE_PURGE_RETENTION_DAYS=30
ARTICLE_LIFECYCLE_PURGE_BATCH_SIZE=100
ARTICLE_LIFECYCLE_PURGE_CRON=0 0 2 * * *
