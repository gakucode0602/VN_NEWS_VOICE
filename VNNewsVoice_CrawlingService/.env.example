# CrawlingService runtime env template
RABBITMQ_URL=amqp://<rabbitmq-user>:<rabbitmq-password>@<rabbitmq-host>:5672/
CRAWL_TASK_QUEUE=crawl.task
CRAWL_TASK_DLX_EXCHANGE=crawl.task.dlx
CRAWL_TASK_DLQ=crawl.task.dlq
CRAWL_TASK_DLQ_ROUTING_KEY=crawl.task.failed
ML_TASKS_QUEUE=ml.tasks

# Publish resilience
ML_PUBLISH_MAX_RETRIES=5
ML_PUBLISH_BACKOFF_INITIAL_SECONDS=0.5
ML_PUBLISH_BACKOFF_MAX_SECONDS=8.0
ML_PUBLISH_JITTER_SECONDS=0.25

# Crawling limits
MAX_ARTICLES_PER_SOURCE=5
MAX_CONCURRENT_CRAWLERS=3

# Pre-ML duplicate guard
ARTICLE_CLAIM_ENABLED=true
ARTICLE_CLAIM_FAIL_OPEN=true
ARTICLE_SERVICE_BASE_URL=http://<article-host>:8080
ARTICLE_CLAIM_ENDPOINT=/api/internal/articles/claim
ARTICLE_CLAIM_TIMEOUT_SECONDS=2.5
LOCAL_RECENT_URL_CACHE_SIZE=5000

LOG_LEVEL=INFO
