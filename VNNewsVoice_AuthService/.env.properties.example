# AuthService runtime env template (.env.properties)
AUTH_SERVICE_PORT=8084
AUTH_DB_URL=jdbc:postgresql://<auth-db-host>:5432/<auth-db-name>
AUTH_DB_USERNAME=<auth-db-username>
AUTH_DB_PASSWORD=<auth-db-password>

# JWT federation
JWT_ISSUER=vnnewsvoice-auth-service
JWT_AUDIENCE=vnnewsvoice-services
JWT_KEY_ID=vnnewsvoice-auth-rs256-k1
JWT_RSA_PRIVATE_KEY_BASE64=<base64-private-key>
JWT_RSA_PUBLIC_KEY_BASE64=<base64-public-key>
JWT_ALLOW_LEGACY_HS256=false
JWT_VERIFY_ISSUER_AUDIENCE=true
JWKS_CACHE_CONTROL_MAX_AGE_SECONDS=300
JWT_SECRET=

# Refresh token and cookie
REFRESH_TOKEN_EXPIRATION_DAYS=7
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_HTTP_ONLY=true
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_DOMAIN=

# External integrations
GOOGLE_CLIENT_ID=<google-oauth-client-id>
CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>
