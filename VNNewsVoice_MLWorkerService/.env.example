# App
PROJECT_NAME=VNNewsVoice ML Worker Service
LOG_LEVEL=INFO

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672/
ML_TASKS_QUEUE=ml.tasks
AMQP_PREFETCH_COUNT=1
ARTICLE_EVENTS_EXCHANGE=article.events

# Summarization providers
# GOOGLE_AI_API_KEY     : used by TTS (Gemini TTS provider)
# GOOGLE_AI_API_KEY_TS  : used by text summarization
# GOOGLE_AI_API_KEY_VEO : used by Veo video generation (optional: fallback to GOOGLE_AI_API_KEY)
GOOGLE_AI_API_KEY=<YOUR_GOOGLE_AI_API_KEY>
GOOGLE_AI_API_KEY_TS=<YOUR_GOOGLE_AI_API_KEY_TS>
GOOGLE_AI_API_KEY_VEO=<YOUR_GOOGLE_AI_API_KEY_VEO>
HUGGINGFACE_API_KEY=<YOUR_HUGGINGFACE_API_KEY>
TTS_PROVIDER=gemini
TTS_MAX_INPUT_CHARS=4000

# Adapter + MLOps
ADAPTER_PATH=models/vit5-qlora-adapter
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=vit5-summarization
SAPO_DATA_PATH=data/processed/pairs.jsonl

# AWS S3 for TTS output
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
AWS_REGION=<YOUR_AWS_REGION>
S3_BUCKET_NAME=<YOUR_S3_BUCKET_NAME>

# Optional admin endpoint guard
ADMIN_SECRET=<YOUR_ADMIN_SECRET>
