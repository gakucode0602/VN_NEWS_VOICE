# Copy this file to .env.infra and fill in STRONG values before running docker compose
# Usage: docker compose --env-file .env.infra -f docker-compose.infra.yml up -d

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_HOST_PORT=5432

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME_strong_password

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_password

# Qdrant (generate with: openssl rand -hex 32)
QDRANT_API_KEY=CHANGE_ME_strong_api_key

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password

# Gateway — create a .env.gateway file in this directory with:
# RAG_UPSTREAM_URL=https://<pod-id>-8000.proxy.runpod.net

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password
